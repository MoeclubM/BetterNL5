<Window
    x:Class="BetterNL5.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="BetterNL5">
    <NavigationView
        x:Name="SidebarNavigationView"
        PaneDisplayMode="Left"
        IsBackButtonVisible="Collapsed"
        IsBackEnabled="False"
        IsSettingsVisible="False"
        CompactModeThresholdWidth="0"
        ExpandedModeThresholdWidth="0"
        SelectionChanged="SidebarNavigationView_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="PowerNavItem" Content="性能" Tag="power" SelectsOnInvoked="True" />
            <NavigationViewItem x:Name="FansNavItem" Content="风扇" Tag="fans" SelectsOnInvoked="True" />
            <NavigationViewItem x:Name="LightingNavItem" Content="灯效" Tag="lighting" SelectsOnInvoked="True" />
        </NavigationView.MenuItems>

        <Grid x:Name="RootGrid" Loaded="RootGrid_Loaded" Padding="20" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock x:Name="PageTitleText" Text="性能" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock x:Name="SubtitleText" Text="正在读取设备状态..." TextWrapping="WrapWholeWords" />
                </StackPanel>

                <ProgressRing x:Name="BusyRing" Grid.Column="1" Width="24" Height="24" IsActive="False" VerticalAlignment="Center" />
            </Grid>

            <InfoBar x:Name="StatusInfoBar" Grid.Row="1" IsOpen="False" Severity="Informational" />

            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16">
                    <StackPanel x:Name="PowerPanel" Spacing="16">
                        <Border Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="性能模式" FontSize="20" FontWeight="SemiBold" />
                                <ToggleSwitch x:Name="ForcePowerToggle" Header="允许在电池或 Type-C 下切换到游戏/狂暴" />
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button x:Name="AudioPowerButton" Content="办公" Click="AudioPowerButton_Click" />
                                    <Button x:Name="GamingPowerButton" Content="游戏" Click="GamingPowerButton_Click" />
                                    <Button x:Name="HighPowerButton" Content="狂暴" Click="HighPowerButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Padding="16">
                            <Grid ColumnSpacing="16" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="当前模式" FontSize="12" />
                                    <TextBlock x:Name="PowerSchemeText" Text="-" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <TextBlock Text="寄存器模式" FontSize="12" />
                                    <TextBlock x:Name="StoredPowerModeText" Text="-" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="WMI 状态" FontSize="12" />
                                    <TextBlock x:Name="RuntimeWmiText" Text="-" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                    <TextBlock Text="BIOS 字" FontSize="12" />
                                    <TextBlock x:Name="BiosWordText" Text="-" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="固件切换" FontSize="12" />
                                    <TextBlock x:Name="FirmwareSupportText" Text="-" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                                    <TextBlock Text="供电状态" FontSize="12" />
                                    <TextBlock x:Name="TypeCAdapterText" Text="-" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Spacing="4">
                                    <TextBlock Text="安装目录" FontSize="12" />
                                    <TextBlock x:Name="InstallDirText" Text="-" TextWrapping="WrapWholeWords" FontWeight="SemiBold" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="FansPanel" Visibility="Collapsed" Spacing="16">
                        <Border Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="风扇状态" FontSize="20" FontWeight="SemiBold" />
                                <Grid ColumnSpacing="16" RowSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                        <TextBlock Text="CPU 温度" FontSize="12" />
                                        <TextBlock x:Name="CpuTempText" Text="-" />
                                        <ProgressBar x:Name="CpuTempBar" Minimum="0" Maximum="100" Value="0" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                        <TextBlock Text="GPU 温度" FontSize="12" />
                                        <TextBlock x:Name="GpuTempText" Text="-" />
                                        <ProgressBar x:Name="GpuTempBar" Minimum="0" Maximum="100" Value="0" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                                        <TextBlock Text="系统温度" FontSize="12" />
                                        <TextBlock x:Name="SysTempText" Text="-" />
                                        <ProgressBar x:Name="SysTempBar" Minimum="0" Maximum="100" Value="0" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                        <TextBlock Text="CPU 转速" FontSize="12" />
                                        <TextBlock x:Name="CpuRpmText" Text="-" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                        <TextBlock Text="GPU 转速" FontSize="12" />
                                        <TextBlock x:Name="GpuRpmText" Text="-" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4">
                                        <TextBlock Text="系统风扇转速" FontSize="12" />
                                        <TextBlock x:Name="SysRpmText" Text="-" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                                        <TextBlock Text="寄存器状态" FontSize="12" />
                                        <TextBlock x:Name="StoredFanStatusText" Text="-" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                                        <TextBlock Text="原始状态" FontSize="12" />
                                        <TextBlock x:Name="RawFanStatusText" Text="-" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="2" Spacing="4">
                                        <TextBlock Text="三风扇支持" FontSize="12" />
                                        <TextBlock x:Name="ThreeFanSupportText" Text="-" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="自定义风扇" FontSize="20" FontWeight="SemiBold" />
                                <ComboBox x:Name="FanProfileComboBox" Header="自定义档位" SelectedIndex="0" SelectionChanged="FanProfileComboBox_SelectionChanged">
                                    <ComboBoxItem Content="自定义风扇 1" Tag="1" />
                                    <ComboBoxItem Content="自定义风扇 2" Tag="2" />
                                    <ComboBoxItem Content="自定义风扇 3" Tag="3" />
                                </ComboBox>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button Content="启用自定义" Click="EnableFanButton_Click" />
                                    <Button Content="按曲线应用" Click="ApplyFanCurveButton_Click" />
                                    <Button Content="关闭自定义" Click="DisableFanButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="手动风扇速度" FontSize="20" FontWeight="SemiBold" />

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Text="CPU" />
                                    <Slider x:Name="CpuFanSlider" Grid.Column="1" Minimum="0" Maximum="100" StepFrequency="1" Value="30" ValueChanged="FanSlider_ValueChanged" />
                                    <TextBlock x:Name="CpuFanSliderText" Grid.Column="2" VerticalAlignment="Center" Text="30%" />
                                </Grid>

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Text="GPU" />
                                    <Slider x:Name="GpuFanSlider" Grid.Column="1" Minimum="0" Maximum="100" StepFrequency="1" Value="30" ValueChanged="FanSlider_ValueChanged" />
                                    <TextBlock x:Name="GpuFanSliderText" Grid.Column="2" VerticalAlignment="Center" Text="30%" />
                                </Grid>

                                <Grid x:Name="SysFanSliderRow" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Text="系统风扇" />
                                    <Slider x:Name="SysFanSlider" Grid.Column="1" Minimum="0" Maximum="100" StepFrequency="1" Value="30" ValueChanged="FanSlider_ValueChanged" />
                                    <TextBlock x:Name="SysFanSliderText" Grid.Column="2" VerticalAlignment="Center" Text="30%" />
                                </Grid>

                                <Button Content="应用手动速度" Click="ApplyManualFanButton_Click" />
                            </StackPanel>
                        </Border>

                        <Border Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="曲线编辑" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="温度档位：30,40,50,60,70,80,90,100" TextWrapping="WrapWholeWords" />
                                <TextBox x:Name="CpuCurveTextBox" Header="CPU 曲线" />
                                <TextBox x:Name="GpuCurveTextBox" Header="GPU 曲线" />
                                <StackPanel x:Name="SysCurveRow">
                                    <TextBox x:Name="SysCurveTextBox" Header="系统风扇曲线" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button Content="读取当前曲线" Click="ReloadCurveButton_Click" />
                                    <Button Content="保存曲线" Click="SaveCurveButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="LightingPanel" Visibility="Collapsed" Spacing="16">
                        <Border Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="灯效预设" FontSize="20" FontWeight="SemiBold" />
                                <ComboBox x:Name="LedModuleComboBox" Header="模块" SelectedIndex="0">
                                    <ComboBoxItem Content="游戏" Tag="game" />
                                    <ComboBoxItem Content="性能" Tag="perf" />
                                    <ComboBoxItem Content="办公" Tag="audio" />
                                    <ComboBoxItem Content="自定义" Tag="custom" />
                                </ComboBox>
                                <Slider x:Name="LedBrightnessSlider" Header="键盘亮度" Minimum="0" Maximum="15" StepFrequency="1" Value="2" ValueChanged="LedBrightnessSlider_ValueChanged" />
                                <TextBlock x:Name="LedBrightnessText" Text="亮度：2" />
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button Content="应用模块" Click="ApplyLedModuleButton_Click" />
                                    <Button Content="保存亮度" Click="ApplyLedBrightnessButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="直接写入" FontSize="20" FontWeight="SemiBold" />
                                <TextBox x:Name="LedModeTextBox" Header="模式" Text="1" />
                                <TextBox x:Name="LedAlphaTextBox" Header="亮度 nibble" Text="2" />
                                <TextBox x:Name="LedRgbTextBox" Header="RGB" Text="FF0080" />
                                <ComboBox x:Name="LedZoneComboBox" Header="区域" SelectedIndex="2">
                                    <ComboBoxItem Content="Logo" Tag="logo" />
                                    <ComboBoxItem Content="Trunk" Tag="trunk" />
                                    <ComboBoxItem Content="LED 1" Tag="led1" />
                                    <ComboBoxItem Content="LED 2" Tag="led2" />
                                    <ComboBoxItem Content="LED 3" Tag="led3" />
                                </ComboBox>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button Content="写入全部区域" Click="SetLedAllButton_Click" />
                                    <Button Content="写入当前区域" Click="SetLedZoneButton_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </NavigationView>
</Window>
